{
  "title": "Eco-Smart Classifier — ML Monitoring",
  "uid": "eco-smart-ml",
  "schemaVersion": 39,
  "refresh": "30s",
  "time": {"from": "now-1h", "to": "now"},
  "panels": [
    {
      "id": 1, "title": "Total Predictions", "type": "stat",
      "gridPos": {"x":0,"y":0,"w":6,"h":4},
      "targets": [{"expr": "sum(predictions_total)", "legendFormat": "Total"}]
    },
    {
      "id": 2, "title": "Predictions par Catégorie", "type": "piechart",
      "gridPos": {"x":6,"y":0,"w":8,"h":8},
      "targets": [{"expr": "sum by (category)(predictions_total)", "legendFormat": "{{category}}"}]
    },
    {
      "id": 3, "title": "Latence p95", "type": "timeseries",
      "gridPos": {"x":0,"y":4,"w":12,"h":8},
      "targets": [{"expr": "histogram_quantile(0.95, sum(rate(api_request_latency_seconds_bucket[5m])) by (le,endpoint))", "legendFormat": "p95 {{endpoint}}"}]
    },
    {
      "id": 4, "title": "Request Rate", "type": "timeseries",
      "gridPos": {"x":12,"y":0,"w":12,"h":8},
      "targets": [{"expr": "sum(rate(api_requests_total[5m])) by (endpoint,status_code)", "legendFormat": "{{endpoint}} {{status_code}}"}]
    },
    {
      "id": 5, "title": "Model Accuracy", "type": "gauge",
      "gridPos": {"x":0,"y":12,"w":6,"h":6},
      "fieldConfig": {"defaults": {"min":0,"max":1,"thresholds":{"steps":[{"value":0,"color":"red"},{"value":0.70,"color":"yellow"},{"value":0.85,"color":"green"}]}}},
      "targets": [{"expr": "model_accuracy", "legendFormat": "{{model}}"}]
    },
    {
      "id": 6, "title": "Text Drift (Jensen-Shannon)", "type": "gauge",
      "gridPos": {"x":6,"y":12,"w":6,"h":6},
      "fieldConfig": {"defaults": {"min":0,"max":1,"thresholds":{"steps":[{"value":0,"color":"green"},{"value":0.20,"color":"yellow"},{"value":0.40,"color":"red"}]}}},
      "targets": [{"expr": "drift_js_divergence", "legendFormat": "JS Divergence"}]
    }
  ]
}
